NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth (Supabase Dashboard > Authentication > Providers > Google 에서 설정)
# 1. Google Cloud Console에서 OAuth 2.0 클라이언트 ID 생성
# 2. Authorized redirect URI: https://<your-supabase-project>.supabase.co/auth/v1/callback
# 3. Supabase Dashboard에서 Google Provider 활성화 후 Client ID/Secret 입력
